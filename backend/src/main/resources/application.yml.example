spring:
  profiles:
    active: local

  datasource:
    url: jdbc:mysql://localhost:3306/smithlife?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect

  jackson:
    time-zone: Asia/Seoul

server:
  port: 8080

jwt:
  secret: YOUR_JWT_SECRET_KEY_AT_LEAST_256_BITS_LONG
  access-token-expiration: 3600000       # 1시간 (ms)
  refresh-token-expiration: 604800000    # 7일 (ms)

logging:
  level:
    com.smithlife: DEBUG
    org.hibernate.SQL: DEBUG
